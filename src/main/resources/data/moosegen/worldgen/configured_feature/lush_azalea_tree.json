        "block_provider": {
          "type": "minecraft:weighted_state_provider",
          "entries": [
            {
              "weight": 1,
              "data": {
                "Name": "minecraft:cave_vines",
                "Properties": {
                  "age": "0",
                  "berries": "false"
                }
              }
            },
            {
              "weight": 1,
              "data": {
                "Name": "minecraft:cave_vines_plant",
                "Properties": {
                  "berries": "true"
                }
              }
            }
          ]
        },
        "directions": [
          "down"
        ]
      }
    ],
    "foliage_placer": {
      "type": "minecraft:fancy_foliage_placer",
