        {
          "weight": 3,
          "data": {
            "Name": "minecraft:azalea_leaves",
            "Properties": {
              "distance": "7",
              "persistent": "false",
              "waterlogged": "false"
            }
          }
        },
        {
          "weight": 1,
          "data": {
            "Name": "minecraft:flowering_azalea_leaves",
            "Properties": {
              "distance": "7",
              "persistent": "false",
              "waterlogged": "false"
            }
          }
        }
