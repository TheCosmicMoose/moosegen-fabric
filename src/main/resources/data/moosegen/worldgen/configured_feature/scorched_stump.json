{
  "type": "minecraft:tree",
  "config": {
    "below_trunk_provider": {
      "type": "minecraft:rule_based_state_provider",
      "rules": [
        {
          "if_true": {
            "type": "minecraft:not",
            "predicate": {
              "type": "minecraft:matching_block_tag",
              "tag": "minecraft:cannot_replace_below_tree_trunk"
            }
          },
          "then": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "minecraft:dirt"
            }
          }
        }
      ]
    },
    "root_placer": {
      "type": "minecraft:mangrove_root_placer",
      "root_provider": {
        "type": "minecraft:simple_state_provider",
        "state": {
          "Name": "minecraft:pale_oak_wood"
        }
      },
      "trunk_offset_y": 0,
      "above_root_placement": {
        "above_root_provider": {
          "type": "minecraft:rule_based_state_provider",
          "rules": [
            {
              "if_true": {
                "type": "minecraft:not",
                "predicate": {
                  "type": "minecraft:matching_blocks",
                  "blocks": "minecraft:pale_oak_log"
                }
              },
              "then": {
                "type": "minecraft:weighted_state_provider",
                "entries": [
                  {
                    "weight": 2,
                    "data": {
                      "Name": "minecraft:pale_moss_carpet"
                    }
                  },
                  {
                    "weight": 1,
                    "data": {
                      "Name": "minecraft:brown_mushroom"
                    }
                  }
                ]
              }
            }
          ]
        },
        "above_root_placement_chance": 0.5
      },
      "mangrove_root_placement": {
        "max_root_width": 4,
        "max_root_length": 3,
        "random_skew_chance": 0.25,
        "can_grow_through": "#minecraft:dirt",
        "muddy_roots_in": "#minecraft:dirt",
        "muddy_roots_provider": {
          "type": "minecraft:simple_state_provider",
          "state": {
            "Name": "minecraft:pale_oak_log",
            "Properties": {
              "axis": "y"
            }
          }
        }
      }
    },
    "decorators": [
      {
        "type": "minecraft:alter_ground",
        "provider": {
          "type": "minecraft:rule_based_state_provider",
          "rules": [
            {
              "if_true": {
                "type": "minecraft:matching_block_tag",
                "tag": "minecraft:beneath_tree_podzol_replaceable"
              },
              "then": {
                "type": "minecraft:weighted_state_provider",
                "entries": [
                  {
                    "weight": 15,
                    "data": {
                      "Name": "minecraft:pale_moss_block"
                    }
                  },
                  {
                    "weight": 1,
                    "data": {
                      "Name": "minecraft:magma_block"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "foliage_placer": {
      "type": "minecraft:mega_pine_foliage_placer",
      "crown_height": {
        "type": "minecraft:uniform",
        "max_inclusive": 1,
        "min_inclusive": 0
      },
      "offset": 0,
      "radius": 0
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "minecraft:air",
        "Properties": {
          "distance": "7",
          "persistent": "false",
          "waterlogged": "false"
        }
      }
    },
    "ignore_vines": false,
    "minimum_size": {
      "type": "minecraft:two_layers_feature_size",
      "limit": 1,
      "lower_size": 1,
      "upper_size": 2
    },
    "trunk_placer": {
      "type": "minecraft:giant_trunk_placer",
      "base_height": 6,
      "height_rand_a": 2,
      "height_rand_b": 4
    },
    "trunk_provider": {
      "type": "minecraft:weighted_state_provider",
      "entries": [
        {
          "weight": 8,
          "data": {
            "Name": "minecraft:polished_basalt",
            "Properties": {
              "axis": "y"
            }
          }
        },
        {
          "weight": 2,
          "data": {
            "Name": "minecraft:pale_oak_log",
            "Properties": {
              "axis": "y"
            }
          }
        },
        {
          "weight": 1,
          "data": {
            "Name": "minecraft:creaking_heart",
            "Properties": {
              "axis": "y",
              "natural": "true"
            }
          }
        }
      ]
    }
  }
}